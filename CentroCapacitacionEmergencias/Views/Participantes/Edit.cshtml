@model CentroCapacitacionEmergencias.Models.ParticipanteFormViewModel
@{
    ViewBag.Title = "Editar participante";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <h1>Editar participante</h1>

    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success">@TempData["Ok"]</div>
    }

    @using (Html.BeginForm("Edit", "Participantes", FormMethod.Post, new { onsubmit = "return validarFormularioParticipante();" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div class="grid-form">
            @Html.TextBoxFor(m => m.TipoIdentificacion, new { @class = "input", @readonly = "readonly", id = "TipoIdentificacion" })
            @Html.TextBoxFor(m => m.Identificacion, new { @class = "input", @readonly = "readonly", id = "Identificacion" })
            @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "input", placeholder = "Nombre completo", id = "NombreCompleto" })
            @Html.TextBoxFor(m => m.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "input", type = "date", id = "FechaNacimiento" })

            @Html.TextBoxFor(m => m.Provincia, new { @class = "input", placeholder = "Provincia", id = "Provincia" })
            @Html.TextBoxFor(m => m.Canton, new { @class = "input", placeholder = "Cantón", id = "Canton" })
            @Html.TextBoxFor(m => m.Distrito, new { @class = "input", placeholder = "Distrito", id = "Distrito" })
            @Html.TextBoxFor(m => m.DetalleDireccion, new { @class = "input", placeholder = "Detalle de dirección", id = "DetalleDireccion" })

            @Html.DropDownListFor(m => m.EstadoCivil,
                new SelectList(new[]
                {
                    new { Value = "", Text = "Seleccione estado civil" },
                    new { Value = "Soltero", Text = "Soltero" },
                    new { Value = "Casado", Text = "Casado" },
                    new { Value = "Divorciado", Text = "Divorciado" },
                    new { Value = "Viudo", Text = "Viudo" }
                }, "Value", "Text", Model.EstadoCivil),
                new { @class = "input", id = "EstadoCivil" })

            @Html.TextBoxFor(m => m.Correo, new { @class = "input", placeholder = "Correo electrónico único", type = "email", id = "Correo" })
            @Html.TextBoxFor(m => m.Telefono, new { @class = "input", placeholder = "Teléfono (opcional)", id = "Telefono" })
            @Html.TextBoxFor(m => m.DireccionResidenciaSecundaria, new { @class = "input", placeholder = "Dirección secundaria (opcional)", id = "DireccionResidenciaSecundaria" })
            @Html.TextBoxFor(m => m.ContactoEmergencia, new { @class = "input", placeholder = "Contacto de emergencia (opcional)", id = "ContactoEmergencia" })
        </div>

        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a class="btn btn-light" href="@Url.Action("Details", new { id = Model.Id })">Cancelar</a>
    }

    <hr />

    <h2>Asignación de cohorte y cursos</h2>
    <p>Después del registro exitoso, el administrador puede asignar o modificar la cohorte y los cursos del participante. :contentReference[oaicite:1]{index=1}</p>

    <div class="grid-form">
        @Html.HiddenFor(m => m.Id, new { id = "ParticipanteIdAsignacion" })
        @Html.DropDownListFor(m => m.CohorteId, Model.Cohortes, "Seleccione cohorte", new { @class = "input", id = "CohorteIdAsignacion" })
        @Html.ListBoxFor(m => m.CursosIds, Model.Cursos, new { @class = "input multiselect", id = "CursosIdsAsignacion" })
        <button type="button" class="btn btn-success" onclick="asignarParticipanteAjax()">Guardar asignación</button>
    </div>
</div>