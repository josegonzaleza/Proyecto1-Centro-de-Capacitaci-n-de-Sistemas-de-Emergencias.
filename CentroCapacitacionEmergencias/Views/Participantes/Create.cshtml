@model CentroCapacitacionEmergencias.Models.ParticipanteFormViewModel
@{
    ViewBag.Title = "Nuevo participante";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <h1>Registrar nuevo participante</h1>

    @using (Html.BeginForm("Create", "Participantes", FormMethod.Post, new { onsubmit = "return validarFormularioParticipante();" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div class="grid-form">
            @Html.DropDownListFor(m => m.TipoIdentificacion,
                new SelectList(new[]
                {
                    new { Value = "", Text = "Seleccione tipo de identificación" },
                    new { Value = "Cédula", Text = "Cédula" },
                    new { Value = "DIMEX", Text = "DIMEX" },
                    new { Value = "Pasaporte", Text = "Pasaporte" }
                }, "Value", "Text", Model.TipoIdentificacion),
                new { @class = "input", id = "TipoIdentificacion" })

            @Html.TextBoxFor(m => m.Identificacion, new { @class = "input", placeholder = "Identificación", id = "Identificacion" })
            @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "input", placeholder = "Nombre completo", id = "NombreCompleto" })
            @Html.TextBoxFor(m => m.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "input", type = "date", id = "FechaNacimiento" })

            @Html.TextBoxFor(m => m.Provincia, new { @class = "input", placeholder = "Provincia", id = "Provincia" })
            @Html.TextBoxFor(m => m.Canton, new { @class = "input", placeholder = "Cantón", id = "Canton" })
            @Html.TextBoxFor(m => m.Distrito, new { @class = "input", placeholder = "Distrito", id = "Distrito" })
            @Html.TextBoxFor(m => m.DetalleDireccion, new { @class = "input", placeholder = "Detalle de dirección", id = "DetalleDireccion" })

            @Html.DropDownListFor(m => m.EstadoCivil,
                new SelectList(new[]
                {
                    new { Value = "", Text = "Seleccione estado civil" },
                    new { Value = "Soltero", Text = "Soltero" },
                    new { Value = "Casado", Text = "Casado" },
                    new { Value = "Divorciado", Text = "Divorciado" },
                    new { Value = "Viudo", Text = "Viudo" }
                }, "Value", "Text", Model.EstadoCivil),
                new { @class = "input", id = "EstadoCivil" })

            @Html.TextBoxFor(m => m.Correo, new { @class = "input", placeholder = "Correo electrónico único", type = "email", id = "Correo" })
            @Html.TextBoxFor(m => m.Telefono, new { @class = "input", placeholder = "Teléfono (opcional)", id = "Telefono" })
            @Html.TextBoxFor(m => m.DireccionResidenciaSecundaria, new { @class = "input", placeholder = "Dirección secundaria (opcional)", id = "DireccionResidenciaSecundaria" })
            @Html.TextBoxFor(m => m.ContactoEmergencia, new { @class = "input", placeholder = "Contacto de emergencia (opcional)", id = "ContactoEmergencia" })
        </div>

        <button type="submit" class="btn btn-primary">Guardar participante</button>
        <a class="btn btn-light" href="@Url.Action("Index")">Cancelar</a>
    }
</div>