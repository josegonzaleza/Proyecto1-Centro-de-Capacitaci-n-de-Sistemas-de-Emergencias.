@model CentroCapacitacionEmergencias.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Ingreso al Sistema</title>
    <link href="~/Content/site.css" rel="stylesheet" />
</head>
<body class="login-body">
    <div class="login-card">
        <h1>Centro de Capacitación</h1>
        <h2>Sistemas de Emergencias</h2>

        @if (ViewBag.Error != null)
        {
        <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Usuario</label>
            @Html.TextBoxFor(m => m.Username, new { @class = "input", autocomplete = "off" })
            @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            @Html.PasswordFor(m => m.Password, new { @class = "input" })
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-primary">Ingresar</button>
        }
    </div>
</body>
</html>