@model CentroCapacitacionEmergencias.Models.EvaluacionViewModel
@{
    ViewBag.Title = "Evaluación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <h1>Evaluación y registro de destrezas</h1>

    <div class="detail-grid">
        <div><strong>Participante:</strong> @Model.ParticipanteNombre</div>
        <div><strong>Curso:</strong> <span id="cursoNombreTexto">@Model.CursoNombre</span></div>
        <div><strong>Destreza:</strong> <span id="destrezaNombreTexto">@Model.DestrezaNombre</span></div>
    </div>

    @using (Html.BeginForm("Create", "Evaluaciones", FormMethod.Post, new { onsubmit = "return validarFormularioEvaluacion();" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ParticipanteId)
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div class="grid-form">
            <div>
                <label>Curso</label>
                @Html.DropDownListFor(m => m.CursoId, Model.CursosDisponibles, "Seleccione curso", new { @class = "input", id = "CursoIdEvaluacion", onchange = "cargarDestrezasAjax();" })
            </div>

            <div>
                <label>Destreza</label>
                @Html.DropDownListFor(m => m.DestrezaId, Model.DestrezasDisponibles, "Seleccione destreza", new { @class = "input", id = "DestrezaIdEvaluacion", onchange = "cargarPuntosControlAjax();" })
            </div>

            <div>
                <label>Tiempo de respuesta (min:seg)</label>
                <div class="time-grid">
                    @Html.TextBoxFor(m => m.TiempoMinutos, new { @class = "input", type = "number", min = "0", id = "TiempoMinutos", placeholder = "Min" })
                    @Html.TextBoxFor(m => m.TiempoSegundos, new { @class = "input", type = "number", min = "0", max = "59", id = "TiempoSegundos", placeholder = "Seg" })
                </div>
            </div>

            <div>
                <label>Puntaje final de ejecución</label>
                @Html.TextBoxFor(m => m.PuntajeOriginal, new { @class = "input", type = "number", min = "1", max = "100", step = "0.01", id = "PuntajeOriginal", placeholder = "Ej: 92" })
            </div>

            <div>
                <label>Aceptación del instructor</label>
                @Html.DropDownListFor(m => m.AceptacionInstructor,
                    new SelectList(new[]
                    {
                        new { Value = "", Text = "Seleccione" },
                        new { Value = "Aprobado por instructor", Text = "Aprobado por instructor" },
                        new { Value = "Requiere reevaluación", Text = "Requiere reevaluación" },
                        new { Value = "Aprobación condicionada", Text = "Aprobación condicionada" }
                    }, "Value", "Text", Model.AceptacionInstructor),
                    new { @class = "input", id = "AceptacionInstructor" })
            </div>

            <div>
                <label>Comentarios</label>
                @Html.TextAreaFor(m => m.Comentarios, new { @class = "input", rows = "4", placeholder = "Observaciones del desempeño" })
            </div>
        </div>

        <div class="form-section">
            <h3>Puntos de control críticos</h3>
            <p class="helper-text">
                Si algún punto crítico se marca como <strong>No Cumplido</strong>, la calificación final se limitará automáticamente al máximo permitido.
            </p>

            <div id="contenedorPuntosControl">
                @if (Model.PuntosControl != null && Model.PuntosControl.Count > 0)
                {
                    for (int i = 0; i < Model.PuntosControl.Count; i++)
                    {
                        <div class="critical-item">
                            @Html.HiddenFor(m => m.PuntosControl[i].PuntoControlId)
                            @Html.HiddenFor(m => m.PuntosControl[i].Descripcion)

                            <div class="critical-title">
                                @Model.PuntosControl[i].Descripcion
                            </div>

                            <div class="radio-group">
                                <label>
                                    @Html.RadioButtonFor(m => m.PuntosControl[i].Cumplido, true)
                                    Cumplido
                                </label>

                                <label>
                                    @Html.RadioButtonFor(m => m.PuntosControl[i].Cumplido, false)
                                    No Cumplido
                                </label>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p>Seleccione una destreza para cargar sus puntos críticos.</p>
                }
            </div>
        </div>

        <div class="actions-bar">
            <button class="btn btn-primary" type="submit">Guardar evaluación</button>
            <a class="btn btn-light" href="@Url.Action("Details", "Participantes", new { id = Model.ParticipanteId })">Cancelar</a>
        </div>
    }
</div>