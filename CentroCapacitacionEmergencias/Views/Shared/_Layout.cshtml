@using CentroCapacitacionEmergencias.Models
@{
    var user = Session["User"] as SessionUser;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Centro de Capacitación</title>
    <link href="~/Content/site.css" rel="stylesheet" />
</head>
<body>
    <header class="topbar">
        <div>
            <strong>Centro de Capacitación de Sistemas de Emergencias</strong>
        </div>
        <div>
            @if (user != null)
            {
                <span>@user.NombreCompleto (@user.Rol)</span>
                <a class="btn btn-light" href="@Url.Action("Logout", "Account")">Salir</a>
            }
        </div>
    </header>

    <div class="wrapper">
        <aside class="sidebar">
            <a href="@Url.Action("Index", "Home")">Inicio</a>
            <a href="@Url.Action("Index", "Participantes")">Participantes</a>
            <a href="@Url.Action("Index", "Monitoreo")">Monitoreo</a>
            <a href="@Url.Action("Cohortes", "Catalogos")">Cohortes</a>
            <a href="@Url.Action("Cursos", "Catalogos")">Cursos</a>
        </aside>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    <script src="@Url.Content("~/Scripts/app.js")?v=2"></script>
</body>
</html>