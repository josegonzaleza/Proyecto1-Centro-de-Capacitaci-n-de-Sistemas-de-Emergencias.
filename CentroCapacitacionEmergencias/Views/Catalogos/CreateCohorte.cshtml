@model CentroCapacitacionEmergencias.Models.CohorteFormViewModel
@{
    ViewBag.Title = "Nueva cohorte";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <h1>Nueva cohorte</h1>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div class="grid-form">
            @Html.TextBoxFor(m => m.Nombre, new { @class = "input", placeholder = "Nombre único de la cohorte" })
            @Html.TextBoxFor(m => m.FechaInicio, "{0:yyyy-MM-dd}", new { @class = "input", type = "date" })
            @Html.TextBoxFor(m => m.FechaFin, "{0:yyyy-MM-dd}", new { @class = "input", type = "date" })
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a class="btn btn-light" href="@Url.Action("Cohortes")">Cancelar</a>
    }
</div>